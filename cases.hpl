  <transform>
    <name>JavaScript</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>var input = date;   // MUST match actual field name
var Cleaned_Date = null;

if (input != null &amp;&amp; input.toString().trim() != "") {

    var dateStr = input.toString().trim();
    dateStr = dateStr.replace(/\s+/g, " ");

    var parsed = null;

    var formats = [
        "yyyy-MM-dd",
        "yyyy/MM/dd",
        "dd/MM/yyyy",
        "d/M/yyyy",
        "MM/dd/yyyy",
        "MMM d yyyy",
        "MMM dd yyyy"
    ];

    var outFormat = new java.text.SimpleDateFormat("yyyy-MM-dd");
    outFormat.setLenient(true);

    for (var i = 0; i &lt; formats.length; i++) {

        try {
            var sdf = new java.text.SimpleDateFormat(formats[i], java.util.Locale.ENGLISH);
            sdf.setLenient(true);

            parsed = sdf.parse(dateStr);

            if (parsed != null) {
                Cleaned_Date = outFormat.format(parsed);
                break;
            }

        } catch (e) {}
    }
}

Cleaned_Date;</jsScript_script>
      </jsScript>
    </jsScripts>
